# Backend
SERVER_PORT=8080
MYSQL_URL=jdbc:mysql://localhost:3306/smart_exam_system?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# Frontend origins allowed to call backend APIs. Use comma-separated patterns in cloud deployment,
# for example: https://your-frontend.vercel.app,https://*.netlify.app
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# Frontend build. Leave empty when frontend and backend are same-origin or proxied by Nginx.
# For Vercel/Netlify static deployment, set this to the public backend URL, for example: https://api.example.com
VITE_API_BASE_URL=

# OpenAI compatible AI service
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_MOCK_ENABLED=true
AI_TIMEOUT_SECONDS=30
