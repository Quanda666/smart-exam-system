# ============================================================
# Smart Exam System - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control!

# ============================================================
# SERVER CONFIGURATION
# ============================================================
# Port for the backend server (Railway/Render will override with their PORT variable)
SERVER_PORT=8080
PORT=8080

# Spring Boot Profile (dev, prod, test)
SPRING_PROFILES_ACTIVE=prod

# ============================================================
# DATABASE CONFIGURATION - MYSQL
# ============================================================
# Local MySQL Example:
# MYSQL_URL=jdbc:mysql://localhost:3306/smart_exam_system?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=root

# PlanetScale Example (MySQL-compatible, free tier available):
# MYSQL_URL=jdbc:mysql://aws.connect.psdb.cloud/smart_exam_system?sslMode=VERIFY_IDENTITY&useSSL=true
# MYSQL_USERNAME=your_username
# MYSQL_PASSWORD=your_password

# Aiven MySQL Example (free tier available):
# MYSQL_URL=jdbc:mysql://mysql-smart-exam-yourproject.aivencloud.com:12345/defaultdb?useSSL=true&requireSSL=true
# MYSQL_USERNAME=avnadmin
# MYSQL_PASSWORD=your_password

# Railway MySQL Example (Railway PostgreSQL can be used with PostgreSQL driver):
# For MySQL on Railway:
# MYSQL_URL=jdbc:mysql://containers-us-west-123.railway.app:1234/railway?useSSL=true
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=your_railway_mysql_password

# Azure MySQL Example:
# MYSQL_URL=jdbc:mysql://your-server.mysql.database.azure.com:3306/smart_exam_system?useSSL=true&requireSSL=true&serverTimezone=UTC
# MYSQL_USERNAME=your_admin@your-server
# MYSQL_PASSWORD=your_password

# Default values for local development:
MYSQL_URL=jdbc:mysql://localhost:3306/smart_exam_system?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# For Docker Compose local development:
MYSQL_DATABASE=smart_exam_system
MYSQL_USER=smartexam
MYSQL_PORT=3306

# ============================================================
# CORS CONFIGURATION
# ============================================================
# Allowed origins for CORS (comma-separated patterns)
# Local development:
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# Production (update with your actual domains):
# CORS_ALLOWED_ORIGIN_PATTERNS=https://your-app.railway.app,https://your-app.onrender.com,https://*.vercel.app

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
# Leave empty for same-origin deployment (recommended)
# Set this only if frontend is deployed separately (e.g., Vercel, Netlify)
VITE_API_BASE_URL=

# For separate frontend deployment:
# VITE_API_BASE_URL=https://your-backend.railway.app

# Frontend port for local development
FRONTEND_PORT=3000

# ============================================================
# AI SERVICE CONFIGURATION (OPTIONAL)
# ============================================================
# OpenAI API Configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Alternative: Use OpenAI-compatible services
# Alibaba Tongyi:
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=sk-your-tongyi-api-key

# Deepseek:
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-your-deepseek-api-key

# Model selection
OPENAI_MODEL=gpt-4o-mini

# Enable mock mode if no API key is provided (returns simulated responses)
AI_MOCK_ENABLED=true

# AI request timeout in seconds
AI_TIMEOUT_SECONDS=30

# ============================================================
# DOCKER COMPOSE CONFIGURATION
# ============================================================
# These are used only for docker-compose.yml local development

# MySQL container configuration
MYSQL_ROOT_PASSWORD=root

# ============================================================
# CLOUD PLATFORM SPECIFIC NOTES
# ============================================================

# RAILWAY:
# - Railway automatically provides PORT variable
# - Add MYSQL_URL, MYSQL_USERNAME, MYSQL_PASSWORD from Railway MySQL plugin
# - Update CORS_ALLOWED_ORIGIN_PATTERNS with your Railway domain

# RENDER:
# - Render automatically provides PORT variable
# - Add MYSQL_URL from external MySQL service (PlanetScale, Aiven, etc.)
# - Update CORS_ALLOWED_ORIGIN_PATTERNS with your Render domain

# FLY.IO:
# - Fly.io uses PORT 8080 by default
# - Add MYSQL_URL as a secret: fly secrets set MYSQL_URL="jdbc:mysql://..."
# - Update CORS_ALLOWED_ORIGIN_PATTERNS with your Fly.io domain

# HEROKU:
# - Heroku automatically provides PORT variable
# - Use JawsDB MySQL or ClearDB add-on, or external MySQL service
# - Update CORS_ALLOWED_ORIGIN_PATTERNS with your Heroku domain

# ============================================================
# SECURITY NOTES
# ============================================================
# 1. Never commit .env file with real credentials
# 2. Use strong passwords for production databases
# 3. Enable SSL/TLS for production database connections
# 4. Rotate API keys and database passwords regularly
# 5. Use environment-specific configurations
# 6. Limit CORS origins to only trusted domains in production
